name: dockercompose3696209092032833778
services:
  api.cronosbot:
    build:
      context: C:\Users\FELIPE\Downloads\csharp\BotAtendimeno
      dockerfile: Api.CronosBot/Dockerfile
      args:
        BUILD_CONFIGURATION: Debug
        LAUNCHING_FROM_VS: "true"
      labels:
        com.microsoft.created-by: visual-studio
        com.microsoft.visual-studio.project-name: Api.CronosBot
      target: base
    entrypoint:
      - dotnet
      - --roll-forward
      - Major
      - /VSTools/DistrolessHelper/DistrolessHelper.dll
      - --wait
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
      ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS: "true"
      DOTNET_USE_POLLING_FILE_WATCHER: "1"
      NUGET_FALLBACK_PACKAGES: /.nuget/fallbackpackages
    image: apicronosbot:dev
    labels:
      com.microsoft.visualstudio.debuggee.arguments: ' --additionalProbingPath /.nuget/packages --additionalProbingPath /.nuget/fallbackpackages  "/app/bin/Debug/net10.0/Api.CronosBot.dll"'
      com.microsoft.visualstudio.debuggee.killprogram: dotnet --roll-forward Major /VSTools/DistrolessHelper/DistrolessHelper.dll --stop dotnet
      com.microsoft.visualstudio.debuggee.program: dotnet
      com.microsoft.visualstudio.debuggee.workingdirectory: /app
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    tty: true
    volumes:
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming\Microsoft\UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming\Microsoft\UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming\ASP.NET\Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming\ASP.NET\Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\Downloads\csharp\BotAtendimeno\Api.CronosBot
        target: /app
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\Downloads\csharp\BotAtendimeno
        target: /src
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\vsdbg\vs2017u5
        target: /remote_debugger
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\.nuget\packages
        target: /.nuget/packages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files (x86)\Microsoft Visual Studio\Shared\NuGetPackages
        target: /.nuget/fallbackpackages
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Insiders\MSBuild\Sdks\Microsoft.Docker.Sdk\tools\linux-x64\net6.0
        target: /VSTools
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Program Files\Microsoft Visual Studio\18\Insiders\Common7\IDE\extensions\Microsoft\managedprojectsystem\HotReload
        target: /HotReloadAgent
        read_only: true
        bind:
          create_host_path: true
  evolution-api:
    container_name: evolution_api
    depends_on:
      postgres_db:
        condition: service_started
        required: true
    environment:
      API_KEY: ChaveSecretaDoFelipe123
      DATABASE_CONNECTION_URI: postgresql://postgres:SuaSenhaSegura123@postgres_db:5432/evolution_db?schema=public
      DATABASE_PROVIDER: postgres
      ENV: dev
      SERVER_URL: http://localhost:8081
    image: evoapicloud/evolution-api:v2.1.1
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8081"
        protocol: tcp
    restart: always
    volumes:
      - type: volume
        source: evolution_instances
        target: /evolution/instances
        volume: {}
  postgres_db:
    container_name: postgres_db
    environment:
      POSTGRES_DB: evolution_db
      POSTGRES_PASSWORD: SuaSenhaSegura123
      POSTGRES_USER: postgres
    image: postgres:15-alpine
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5432"
        protocol: tcp
    restart: always
    volumes:
      - type: volume
        source: postgres_data
        target: /var/lib/postgresql/data
        volume: {}
networks:
  default:
    name: dockercompose3696209092032833778_default
volumes:
  evolution_instances:
    name: dockercompose3696209092032833778_evolution_instances
  postgres_data:
    name: dockercompose3696209092032833778_postgres_data