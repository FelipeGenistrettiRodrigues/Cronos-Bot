name: dockercompose3696209092032833778
services:
  api.cronosbot:
    build:
      context: C:\Users\FELIPE\Downloads\csharp\BotAtendimeno
      dockerfile: Api.CronosBot/Dockerfile
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
    image: apicronosbot
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
  evolution-api:
    container_name: evolution_api
    environment:
      API_KEY: ChaveSecretaDoFelipe123
      ENV: dev
      SERVER_URL: http://localhost:8080
    image: evolutionapi/evolution-api:latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8081"
        protocol: tcp
    volumes:
      - type: volume
        source: evolution_data
        target: /evolution/instances
        volume: {}
networks:
  default:
    name: dockercompose3696209092032833778_default
volumes:
  evolution_data:
    name: dockercompose3696209092032833778_evolution_data