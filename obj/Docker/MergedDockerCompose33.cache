name: dockercompose3696209092032833778
services:
  api.cronosbot:
    build:
      context: C:\Users\FELIPE\Downloads\csharp\BotAtendimeno
      dockerfile: Api.CronosBot/Dockerfile
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
    image: apicronosbot
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming/Microsoft/UserSecrets
        target: /home/app/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming/Microsoft/UserSecrets
        target: /root/.microsoft/usersecrets
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming/ASP.NET/Https
        target: /home/app/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
      - type: bind
        source: C:\Users\FELIPE\AppData\Roaming/ASP.NET/Https
        target: /root/.aspnet/https
        read_only: true
        bind:
          create_host_path: true
  evolution-api:
    depends_on:
      postgres_db:
        condition: service_started
        required: true
    environment:
      API_KEY: ChaveSecretaDoFelipe123
      AUTHENTICATION_API_KEY: ChaveSecretaDoFelipe123
      CACHE_PROVIDER: local
      DATABASE_CONNECTION_CLIENT: pg
      DATABASE_CONNECTION_URI: postgresql://postgres:SuaSenhaSegura123@postgres_db:5432/evolution_db?schema=public
      DATABASE_PROVIDER: postgresql
      ENV: dev
      REDIS_ENABLED: "false"
      SERVER_URL: http://localhost:8081
    image: evoapicloud/evolution-api:v2.1.1
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8081"
        protocol: tcp
    restart: always
    volumes:
      - type: volume
        source: evolution_instances
        target: /evolution/instances
        volume: {}
  postgres_db:
    environment:
      POSTGRES_DB: evolution_db
      POSTGRES_PASSWORD: SuaSenhaSegura123
      POSTGRES_USER: postgres
    image: postgres:15-alpine
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5433"
        protocol: tcp
    restart: always
    volumes:
      - type: volume
        source: postgres_data
        target: /var/lib/postgresql/data
        volume: {}
networks:
  default:
    name: dockercompose3696209092032833778_default
volumes:
  evolution_instances:
    name: dockercompose3696209092032833778_evolution_instances
  postgres_data:
    name: dockercompose3696209092032833778_postgres_data